{
  "name": "iot-monitoring-system",
  "version": "1.0.0",
  "description": "IoT Monitoring System with MQTT, GPS, and Multi-protocol Support",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "start:prod": "npm run build && node server/index.js",
    "dev": "nodemon server/index.js",
    "build": "cd client && npm run build",
    "install-all": "npm install && cd client && npm install",
    "setup-db": "node scripts/setup-database.js",
    "create-test-devices": "node scripts/create-test-devices.js",
    "migrate": "node scripts/migrate.js",
    "test-notifications": "node scripts/test-notification-integration.js"
  },
  "keywords": [
    "iot",
    "mqtt",
    "monitoring",
    "gps",
    "sensors"
  ],
  "author": "IoT Monitoring System",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "moment-timezone": "^0.5.43",
    "mqtt": "^5.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.2",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0",
    "winston": "^3.10.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
