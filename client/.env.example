# Vite / frontend env (optional)
# Copy to .env and adjust if your API is not on localhost:3000

# Dev server: proxy target for /api requests (default: http://localhost:3000)
# VITE_PROXY_TARGET=http://localhost:3000

# Production build: API and WebSocket base URLs (when frontend is on a different host)
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_WS_BASE_URL=https://api.yourdomain.com
