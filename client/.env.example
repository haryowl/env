# Vite / frontend env (optional)
# Copy to client/.env and rebuild (npm run build) for changes to apply

# Dev server: proxy target for /api requests (default: http://localhost:3000)
# VITE_PROXY_TARGET=http://localhost:3000

# Production build: API and WebSocket base URLs
# Use when frontend is on different host, OR when browser forces HTTPS upgrade (ERR_SSL_PROTOCOL_ERROR)
# Force HTTP (e.g. Chrome "Always use secure connections"): set your server IP and port
# VITE_API_BASE_URL=http://81.17.100.7:3000
# VITE_WS_BASE_URL=http://81.17.100.7:3000
