# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=iot_monitoring
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=24h

# MQTT Configuration
# Local broker (requires Mosquitto or similar)
MQTT_BROKER_URL=mqtt://localhost:1883
# Alternative: Public test broker (for development only)
# MQTT_BROKER_URL=mqtt://test.mosquitto.org:1883
# Alternative: HiveMQ public broker
# MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=monitoring_server

# Redis (optional - not currently used by the app; reserve for future session/cache)
# REDIS_URL=redis://localhost:6379

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log
# Set DB_LOG_QUERIES=true to log every SQL query (noisy; default: only in development)
# DB_LOG_QUERIES=false

# CORS / Socket.IO allowed origins (comma-separated; used in production)
# Example: CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
# If unset, defaults include localhost and common hosts
# CORS_ORIGINS=

# Security
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX=100

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Timezone
DEFAULT_TIMEZONE=UTC

# Backup Configuration
BACKUP_PATH=backups/
BACKUP_RETENTION_DAYS=30

# ---- Client (frontend) ----
# Optional: set in client/.env for Vite dev server and build.
# VITE_API_BASE_URL=http://localhost:3000/api   (production API URL when frontend is on different host)
# VITE_WS_BASE_URL=http://localhost:3000        (WebSocket/Socket.IO URL when different from same origin)
# VITE_PROXY_TARGET=http://localhost:3000       (dev only: where to proxy /api requests; default localhost:3000)